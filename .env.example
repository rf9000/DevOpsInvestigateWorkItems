# Azure DevOps Configuration (required)
AZURE_DEVOPS_PAT=your-personal-access-token
AZURE_DEVOPS_ORG=your-org-name
AZURE_DEVOPS_PROJECT=your-project-name
FEATURE_WORK_ITEM_IDS=12345,67890
TARGET_REPO_PATH=C:/path/to/local/repo

# Optional: Polling interval in minutes (default: 15)
# POLL_INTERVAL_MINUTES=15

# Optional: Max investigations per day (default: 5)
# MAX_INVESTIGATIONS_PER_DAY=5

# Optional: Claude model to use (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: Path to AI prompt file (default: src/prompts/investigate-bug.md)
# PROMPT_PATH=src/prompts/investigate-bug.md

# Optional: Only investigate bugs assigned to these people (comma-separated, default: all)
# ASSIGNED_TO_FILTER=Alice Smith,Bob Jones

# Optional: State file directory (default: .state)
# STATE_DIR=.state
